services:
  gophish:
    image: {{ phishing_simulator_docker_image }}
    container_name: gophish
    restart: unless-stopped
    ports:
      - "{{ phishing_simulator_admin_port }}:{{ phishing_simulator_admin_port }}"
      - "{{ phishing_simulator_phishing_port }}:{{ phishing_simulator_phishing_port }}"
    volumes:
      - ./config.json:/opt/gophish/config.json:ro
      - gophish-data:/opt/gophish

volumes:
  gophish-data:
