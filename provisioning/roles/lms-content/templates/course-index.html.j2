<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ lms_content_course_title }}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background: #f0f2f5; color: #222; }
    header { background: #1a3a5c; color: #fff; padding: 20px 40px; }
    header h1 { font-size: 22px; }
    header p  { font-size: 13px; margin-top: 4px; opacity: .8; }
    nav { display: flex; gap: 4px; background: #122a45; padding: 0 40px; }
    nav button { background: none; border: none; color: #adc6e0; padding: 12px 18px;
                 cursor: pointer; font-size: 14px; border-bottom: 3px solid transparent; }
    nav button.active, nav button:hover { color: #fff; border-bottom-color: #4a9fd4; }
    main { max-width: 860px; margin: 30px auto; padding: 0 20px; }
    .tab { display: none; }
    .tab.active { display: block; }
    .card { background: #fff; border-radius: 6px; padding: 28px 32px;
            box-shadow: 0 1px 4px rgba(0,0,0,.1); margin-bottom: 20px; }
    .card h2 { font-size: 18px; color: #1a3a5c; margin-bottom: 12px; }
    .card h3 { font-size: 15px; color: #2c5282; margin: 18px 0 8px; }
    .card p, .card li { font-size: 14px; line-height: 1.7; }
    .card ul, .card ol { padding-left: 22px; margin-top: 6px; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 12px;
             font-size: 12px; font-weight: bold; margin-bottom: 10px; }
    .badge.theory { background: #e3f2fd; color: #1565c0; }
    .badge.exercise { background: #fce4ec; color: #b71c1c; }
    .badge.complete { background: #e8f5e9; color: #1b5e20; }
    .highlight { background: #fff8e1; border-left: 4px solid #f9a825;
                 padding: 10px 14px; margin: 12px 0; border-radius: 0 4px 4px 0; }
    .warn { background: #fdecea; border-left: 4px solid #e53935;
            padding: 10px 14px; margin: 12px 0; border-radius: 0 4px 4px 0; }
    .checklist label { display: flex; align-items: flex-start; gap: 10px;
                       margin-bottom: 10px; cursor: pointer; font-size: 14px; }
    .checklist input { margin-top: 3px; width: 16px; height: 16px; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 4px;
           border: none; cursor: pointer; font-size: 14px; font-weight: bold;
           margin-top: 14px; }
    .btn-primary { background: #1a3a5c; color: #fff; }
    .btn-primary:hover { background: #2c5282; }
    .btn-danger { background: #c0392b; color: #fff; }
    .url-box { background: #f5f5f5; border: 1px solid #ddd; border-radius: 4px;
               padding: 8px 12px; font-family: monospace; font-size: 13px;
               word-break: break-all; margin: 8px 0; }
    .score-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 12px; }
    .score-item { background: #f8f9fa; border-radius: 6px; padding: 14px;
                  border-left: 4px solid #4a9fd4; }
    .score-item .weight { font-size: 22px; font-weight: bold; color: #1a3a5c; }
    .score-item .label { font-size: 12px; color: #666; margin-top: 2px; }
    footer { text-align: center; padding: 20px; font-size: 12px; color: #888; }
  </style>
